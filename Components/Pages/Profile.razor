@page "/profile-user"
@inject NavigationManager Nav
@using DocArchiveAdmin.Services
@inject UserService UserService
@using Microsoft.Maui.Storage
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@using System.Linq

<head>
    <link href="css/profile.css" rel="stylesheet" />
</head>

<div class="profile-container">

    <!-- PROFILE CARD -->
    <div class="profile-card">

        <div class="profile-card-header">
            <h1>User Profile</h1>

            <button class="edit-button" @onclick="ToggleEditMode">
                @(isEditMode ? "Cancel" : "Edit")
            </button>
        </div>

        <div class="profile-content">

            <!-- PROFILE HEADER -->
            <div class="profile-section">
                <div class="avatar-name-section">
                    <div class="avatar-circle">@initials</div>

                    <div class="name-info">
                        <h2>@username</h2>
                        <p class="rank">@fullName</p>
                        <p class="organization">Employee ID: @userCode</p>
                    </div>
                </div>
            </div>

            <!-- EMAIL (READ ONLY) -->
            <div class="profile-row">
                <span class="icon">✉️</span>
                <span class="label">Email:</span>
                <input class="form-input readonly" value="@email" readonly />
            </div>

            <!-- PHONE (EDITABLE) -->
            <div class="profile-row">
                <span class="icon">📱</span>
                <span class="label">Phone:</span>
                <input class="form-input"
                       @bind="editPhone"
                       readonly="@(!isEditMode)" />
            </div>

            <!-- ADDRESS (EDITABLE) -->
            <div class="profile-row">
                <span class="icon">📍</span>
                <span class="label">Address:</span>
                <input class="form-input"
                       @bind="editAddress"
                       readonly="@(!isEditMode)" />
            </div>

            <!-- ROLE (READ ONLY) -->
            <div class="profile-row">
                <span class="icon">🛡️</span>
                <span class="label">Role:</span>
                <input class="form-input readonly" value="@role" readonly />
            </div>

        </div>

        <!-- ACTION BUTTONS -->
        <div class="form-actions">
            @if (isEditMode)
            {
                <button class="save-button" @onclick="SaveProfile">
                    Save Changes
                </button>
            }
        </div>

    </div>

    <!-- BACK BUTTON -->
    <div class="back-button-container">
        <button class="back-button" @onclick="@(() => Nav.NavigateTo("/dashboard"))">
            ← Back to Dashboard
        </button>
    </div>

</div>

@code {

    private bool isEditMode;

    private string username = "";
    private string fullName = "";
    private string email = "";
    private string phone = "";
    private string address = "";
    private string userCode = "";
    private string role = "";
    private string initials = "";

    private string editPhone = "";
    private string editAddress = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadJwtData();
    }

    private async Task LoadJwtData()
    {
        var token = await SecureStorage.GetAsync("jwt_token");

        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/");
            return;
        }

        var handler = new JwtSecurityTokenHandler();
        var jwt = handler.ReadJwtToken(token);

        username = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Name)?.Value ?? "";
        role = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "Employee";

        fullName = jwt.Claims.FirstOrDefault(c => c.Type == "fullName")?.Value ?? username;
        email = jwt.Claims.FirstOrDefault(c => c.Type == "email")?.Value ?? "";
        phone = jwt.Claims.FirstOrDefault(c => c.Type == "phone")?.Value ?? "";
        address = jwt.Claims.FirstOrDefault(c => c.Type == "address")?.Value ?? "";
        userCode = jwt.Claims.FirstOrDefault(c => c.Type == "userCode")?.Value ?? "";

        initials = string.Join("",
            fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x[0])
        ).ToUpper();

        editPhone = phone;
        editAddress = address;
    }

    private void ToggleEditMode()
    {
        if (isEditMode)
        {
            // revert changes
            editPhone = phone;
            editAddress = address;
        }

        isEditMode = !isEditMode;
    }

    private async Task SaveProfile()
    {
        Console.WriteLine("Saving...");

        var success = await UserService.UpdateProfile(editPhone, editAddress);

        if (success)
        {
            // ✅ Update UI directly
            phone = editPhone;
            address = editAddress;

            isEditMode = false;

            Console.WriteLine("Update success");
        }
        else
        {
            Console.WriteLine("Update failed");
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/dashboard");
    }
}