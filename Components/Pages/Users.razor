@page "/user-management"
@layout MainLayout
@inject NavigationManager Nav
@inject UserService UserService

@using DocArchiveAdmin.Models
@using DocArchiveAdmin.Services
@using DocArchiveAdmin.DTOs

<head>
    <link href="css/users.css" rel="stylesheet" />
</head>

<div class="content">
    <!-- Page Header -->
    <div class="header-title">
        <h1>USER MANAGEMENT</h1>
        <p>Manage and monitor all users in the system</p>
    </div>

    <!-- Search Section -->
    <div class="search-section">
        <div class="search-wrapper">
            <input type="text"
                   class="search-input"
                   placeholder="SEARCH USERS"
                   @bind="searchQuery"
                   @oninput="@((ChangeEventArgs e) => OnSearchChanged(e.Value?.ToString()))" />
            <span class="search-icon">🔍</span>
        </div>
    </div>

    <!-- Users Table -->
    <div class="table-wrapper">
        <table class="users-table">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (filteredUsers.Count > 0)
                {
                    @foreach (var user in filteredUsers)
                    {
                        <tr>

                            <td class="email">@user.Email</td>

                            <td class="status">
                                <span class="status-badge @(user.Status?.ToLower())">
                                    @user.Status
                                </span>
                            </td>

                            <td class="role">
                                <span class="role-badge @GetRoleBadgeClass(user.Role)">
                                    @user.Role
                                </span>
                            </td>

                            <td class="joined">@user.JoinedDate.ToString("MM-dd-yy")</td>

                            <td class="actions">
                                <button class="action-button" @onclick="@(() => OpenActionMenu(user.Id))">
                                    ⋮
                                </button>

                                @if (openActionMenuId == user.Id)
                                {
                                    <div class="action-menu">
                                        <button class="menu-item" @onclick="@(() => ViewUser(user))">
                                            <span class="menu-icon">👁️</span> View
                                        </button>

                                        <button class="menu-item" @onclick="@(() => EditUser(user))">
                                            <span class="menu-icon">✏️</span> Edit
                                        </button>

                                        <button class="menu-item" @onclick="@(() => ResetPassword(user))">
                                            <span class="menu-icon">🔑</span> Reset Password
                                        </button>

                                        <button class="menu-item delete" @onclick="@(() => DeactivateUser(user))">
                                            <span class="menu-icon">🚫</span>
                                            @(user.Status == "Active" ? "Deactivate" : "Activate")
                                        </button>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-state">No users found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<User> allUsers = new();
    private List<User> filteredUsers = new();
    private string searchQuery = "";
    private int? openActionMenuId = null;

    // =========================
    // LOAD USERS FROM API
    // =========================
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var usersFromDb = await UserService.GetAllUsersAsync();

            allUsers = usersFromDb.Select(u => new User
            {
                Id = u.Id,
                UserId = u.UserCode ?? "N/A",
                Email = u.Email ?? "N/A",
                Status = u.Status ?? "Inactive",
                Role = u.Role ?? "Unknown",
                JoinedDate = u.JoinedDate
            }).ToList();

            filteredUsers = allUsers;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
        }
    }

    // =========================
    // SEARCH
    // =========================
    private void OnSearchChanged(string query)
    {
        searchQuery = query ?? "";
        ApplySearch();
    }

    private void ApplySearch()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            filteredUsers = allUsers;
        }
        else
        {
            var lowerSearch = searchQuery.ToLower();

            filteredUsers = allUsers
                .Where(u =>
                    (u.UserId ?? "").ToLower().Contains(lowerSearch) ||
                    (u.Email ?? "").ToLower().Contains(lowerSearch) ||
                    (u.Role ?? "").ToLower().Contains(lowerSearch))
                .ToList();
        }
    }

    // =========================
    // ACTION MENU
    // =========================
    private void OpenActionMenu(int userId)
    {
        openActionMenuId = openActionMenuId == userId ? null : userId;
    }

    // =========================
    // ACTIONS
    // =========================
    private void ViewUser(User user)
    {
        Nav.NavigateTo($"/user-details/{user.Id}");
        openActionMenuId = null;
    }

    private void EditUser(User user)
    {
        Nav.NavigateTo($"/edit-user/{user.Id}");
        openActionMenuId = null;
    }

    private async Task ResetPassword(User user)
    {
        var success = await UserService.ResetPasswordAsync(user.Id);

        Console.WriteLine(success
            ? $"Password reset for {user.Email}"
            : $"Failed to reset password");

        openActionMenuId = null;
    }

    private async Task DeactivateUser(User user)
    {
        var success = await UserService.ToggleUserStatusAsync(user.Id);

        if (success)
        {
            user.Status = user.Status == "Active" ? "Inactive" : "Active";
        }

        openActionMenuId = null;
    }

    // =========================
    // UI HELPERS
    // =========================
    private string GetRoleBadgeClass(string role)
    {
        return role?.ToLower() switch
        {
            "military personnel" => "military",
            "civilian" => "civilian",
            "admin" => "admin",
            _ => "civilian"
        };
    }

    // =========================
    // LOCAL UI MODEL
    // =========================
    public class User
    {
        public int Id { get; set; }
        public string UserId { get; set; }   // UserCode
        public string Email { get; set; }
        public string Status { get; set; }
        public string Role { get; set; }
        public DateTime JoinedDate { get; set; }
    }
}