@page "/setup-admin"
@inject HttpClient Http
@inject NavigationManager Nav
@layout EmptyLayout

<head>
    <link href="css/adminsetup.css" rel="stylesheet" />
</head>

<div class="setup-page">

    <div class="setup-card">

        <div class="setup-header">
            <h2>🛡️ Create First Admin</h2>
            <p>Setup your system administrator account</p>
        </div>

        <EditForm Model="@model" OnValidSubmit="CreateAdmin">

            <!-- USERNAME -->
            <div class="input-group">
                <label>Username</label>
                <InputText class="input" @bind-Value="model.Username" placeholder="Enter username" />
            </div>

            <!-- FULL NAME -->
            <div class="input-group">
                <label>Full Name</label>
                <InputText class="input" @bind-Value="model.FullName" placeholder="Enter full name" />
            </div>

            <!-- PASSWORD -->
            <div class="input-group">
                <label>Password</label>
                <InputText class="input" type="password" @bind-Value="model.Password" placeholder="Enter password" />
            </div>

            <!-- CONFIRM PASSWORD -->
            <div class="input-group">
                <label>Confirm Password</label>
                <InputText class="input" type="password" @bind-Value="confirmPassword" placeholder="Confirm password" />
            </div>

            @if (!string.IsNullOrEmpty(passwordError))
            {
                <div class="error">@passwordError</div>
            }

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="message">@message</div>
            }

            <!-- SUBMIT -->
            <button class="btn-primary" type="submit">
                Create Admin
            </button>

        </EditForm>

    </div>

</div>

@code {
    private CreateAdminModel model = new();
    private string confirmPassword;
    private string message;
    private string passwordError;

    // ================= CREATE ADMIN =================
    private async Task CreateAdmin()
    {
        passwordError = "";
        message = "";

        // 🔐 Required fields check
        if (string.IsNullOrWhiteSpace(model.Username) ||
            string.IsNullOrWhiteSpace(model.FullName) ||
            string.IsNullOrWhiteSpace(model.Password))
        {
            passwordError = "All fields are required.";
            return;
        }

        // 🔐 Password match check
        if (model.Password != confirmPassword)
        {
            passwordError = "Passwords do not match.";
            return;
        }

        // 🔐 Strong password check
        if (!IsStrongPassword(model.Password))
        {
            passwordError =
                "Password must be at least 8 characters and include uppercase, lowercase, number, and special character.";
            return;
        }

        try
        {
            // 🔥 FIXED API CALL (NO ROLE ERROR)
            var res = await Http.PostAsJsonAsync("api/users/create-first-admin", new
            {
                Username = model.Username,
                FullName = model.FullName,
                Password = model.Password
            });

            if (res.IsSuccessStatusCode)
            {
                message = "Admin created successfully! Redirecting...";

                await Task.Delay(1000);
                Nav.NavigateTo("/", true);
            }
            else
            {
                message = await res.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            message = "Error: " + ex.Message;
        }
    }

    // ================= PASSWORD RULES =================
    private bool IsStrongPassword(string password)
    {
        if (string.IsNullOrWhiteSpace(password))
            return false;

        return password.Length >= 8
            && password.Any(char.IsUpper)
            && password.Any(char.IsLower)
            && password.Any(char.IsDigit)
            && password.Any(ch => !char.IsLetterOrDigit(ch));
    }

    // ================= MODEL =================
    public class CreateAdminModel
    {
        public string Username { get; set; }
        public string FullName { get; set; }
        public string Password { get; set; }
    }
}