@page "/create-user"
@layout MainLayout
@inject NavigationManager Nav
@inject UserService UserService
@using System.Text
@using DocArchiveAdmin.Models
@using DocArchiveAdmin.Services
@using DocArchiveAdmin.DTOs

<link rel="stylesheet" href="css/create-user.css" />

<div class="content">

    <!-- HEADER -->
    <div class="create-user-header">
        <h1>CREATE NEW USER</h1>
        <p>Add a new user account to the system</p>
    </div>

    <!-- FORM -->
    <div class="form-container">

        <EditForm Model="@userModel" OnSubmit="HandleCreateUser">

            <!-- BASIC INFO -->
            <div class="form-section">
                <div class="section-title">📋 Basic Information</div>

                <div class="form-grid">

                    <input class="form-input" value="@userModel.UserCode" disabled />

                    <input class="form-input @(usernameError ? "input-error" : "")"
                           placeholder="Username"
                           @bind="userModel.Username"
                           @oninput="ClearError" />

                    @if (usernameError)
                    {
                        <small class="error-text">Username is required</small>
                    }

                    <input class="form-input"
                           placeholder="Full Name"
                           @bind="userModel.FullName" />

                    <input class="form-input"
                           placeholder="Email"
                           value="@userModel.Email"
                           @oninput="ValidateEmail" />

                    @if (!string.IsNullOrEmpty(emailError))
                    {
                        <small class="error-text">@emailError</small>
                    }

                    <!-- PHONE -->
                    <div class="phone-wrapper full-width">
                        <span class="phone-prefix"></span>
                        <input class="form-input"
                               placeholder="Contact Number"
                               value="@userModel.ContactNumber"
                               @oninput="FormatContactNumber" />
                    </div>

                    <input class="form-input full-width"
                           placeholder="Address"
                           @bind="userModel.Address" />

                </div>
            </div>

            <!-- ACCOUNT SETUP -->
            <div class="form-section">

                <div class="section-title">🔐 Account Setup</div>

                <div class="account-box">

                    <div class="account-grid">

                        <div class="password-wrapper">
                            <input type="@passwordType"
                                   class="form-input @(passwordError ? "input-error" : "")"
                                   placeholder="Password"
                                   @bind="userModel.TemporaryPassword"
                                   @oninput="ClearError" />

                            <span class="password-toggle"
                                  @onclick="TogglePasswordVisibility">
                                👁️
                            </span>
                        </div>

                        @if (passwordError)
                        {
                            <small class="error-text">Minimum 8 characters</small>
                        }

                        <button type="button"
                                class="generate-btn"
                                @onclick="GenerateSecurePassword">
                            Generate Secure Password
                        </button>

                        <label class="status-box">
                            <input type="checkbox"
                                   @bind="userModel.ForcePasswordChangeOnLogin" />
                            Force password change on login
                        </label>

                    </div>
                </div>
            </div>

            <!-- ROLE -->
            <div class="form-section">
                <div class="section-title">Role</div>

                <div class="role-box">
                    <select class="form-input @(roleError ? "input-error" : "")"
                            @bind="userModel.Role"
                            @bind:after="ClearError">

                        <option value="">Select Role</option>
                        <option>Admin</option>
                        <option>Manager</option>
                        <option>Staff</option>
                        <option>Viewer</option>

                    </select>
                </div>
            </div>

            <!-- STATUS -->
            <div class="form-section">
                <div class="status-box">
                    <input type="checkbox" @bind="userModel.IsActive" />
                    <label>Active Account</label>
                </div>
            </div>

            <!-- ACTIONS -->
            <div class="form-actions">
                <button type="submit" class="btn-primary" disabled="@isSubmitting">
                    @(isSubmitting ? "Creating..." : "Create User")
                </button>

                <button type="button" class="btn-secondary" @onclick="GoBack">
                    Cancel
                </button>
            </div>

            @if (showSuccessMessage)
            {
                <p style="color:#1f6f46; margin-top:15px;">User created successfully!</p>
            }

            @if (!string.IsNullOrEmpty(generalError))
            {
                <p style="color:#ef4444; margin-top:15px;">@generalError</p>
            }

        </EditForm>
    </div>
</div>

@code {

    private UserCreateModel userModel = new();

    private string passwordType = "password";
    private bool isSubmitting = false;
    private bool showSuccessMessage = false;
    private string generalError = "";

    private bool usernameError = false;
    private bool passwordError = false;
    private bool roleError = false;

    private string emailError = "";

    // =========================
    // INIT
    // =========================
    protected override Task OnInitializedAsync()
    {
        userModel.UserCode = GenerateUserCode();
        userModel.ForcePasswordChangeOnLogin = true;
        userModel.IsActive = true;
        userModel.ContactNumber = "+63";

        return Task.CompletedTask;
    }

    // =========================
    // USER CODE GENERATOR
    // =========================
    private string GenerateUserCode()
    {
        var random = new Random();
        return random.Next(10000, 99999).ToString();
    }

    // =========================
    // PASSWORD TOGGLE
    // =========================
    private void TogglePasswordVisibility()
    {
        passwordType = passwordType == "password" ? "text" : "password";
    }

    // =========================
    // PASSWORD GENERATOR
    // =========================
    private void GenerateSecurePassword()
    {
        const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*";
        var random = new Random();

        userModel.TemporaryPassword = new string(
            Enumerable.Repeat(chars, 12)
            .Select(s => s[random.Next(s.Length)]).ToArray()
        );
    }

    // =========================
    // EMAIL VALIDATION
    // =========================
    private void ValidateEmail(ChangeEventArgs e)
    {
        userModel.Email = e.Value?.ToString();

        if (string.IsNullOrWhiteSpace(userModel.Email))
        {
            emailError = "Email is required";
        }
        else if (!userModel.Email.Contains("@"))
        {
            emailError = "Email must contain @";
        }
        else
        {
            emailError = "";
        }
    }

    // =========================
    // CONTACT FORMAT (+63)
    // =========================
    private void FormatContactNumber(ChangeEventArgs e)
    {
        var input = e.Value?.ToString() ?? "";

        if (!input.StartsWith("+63"))
            input = "+63";

        var digits = new string(input.Skip(3).Where(char.IsDigit).ToArray());

        if (digits.Length > 10)
            digits = digits.Substring(0, 10);

        userModel.ContactNumber = "+63" + digits;
    }

    // =========================
    // CLEAR ERRORS
    // =========================
    private void ClearError()
    {
        usernameError = false;
        passwordError = false;
        roleError = false;
        generalError = "";
    }

    // =========================
    // SUBMIT
    // =========================
    private async Task HandleCreateUser()
    {
        usernameError = string.IsNullOrWhiteSpace(userModel.Username);
        passwordError = string.IsNullOrWhiteSpace(userModel.TemporaryPassword) || userModel.TemporaryPassword.Length < 8;
        roleError = string.IsNullOrWhiteSpace(userModel.Role);

        if (usernameError || passwordError || roleError || !string.IsNullOrEmpty(emailError))
            return;

        isSubmitting = true;

        try
        {
            var dto = new UserCreateDto
            {
                UserCode = userModel.UserCode,
                Username = userModel.Username,
                Password = userModel.TemporaryPassword,
                FullName = userModel.FullName,
                Email = userModel.Email,
                ContactNumber = userModel.ContactNumber,
                Address = userModel.Address,
                Role = userModel.Role,
                IsActive = userModel.IsActive,
                ForcePasswordChangeOnLogin = userModel.ForcePasswordChangeOnLogin
            };

            await UserService.CreateUserAsync(dto);

            showSuccessMessage = true;

            await Task.Delay(1500);
            Nav.NavigateTo("/user-management");
        }
        catch (Exception ex)
        {
            generalError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/user-management");
    }

    // =========================
    // MODEL
    // =========================
    public class UserCreateModel
    {
        public string? UserCode { get; set; }
        public string Username { get; set; }
        public string FullName { get; set; }

        public string? Email { get; set; }
        public string? ContactNumber { get; set; }
        public string? Address { get; set; }

        public string TemporaryPassword { get; set; }
        public bool ForcePasswordChangeOnLogin { get; set; }
        public string Role { get; set; }
        public bool IsActive { get; set; }
    }
}