@page "/"
@inject NavigationManager Nav
@inject HttpClient Http
@layout EmptyLayout
@inject WindowService WindowService
@inject IJSRuntime JS
@using DocArchiveAdmin.Models
@using DocArchiveAdmin.Services

<head>
    <link rel="stylesheet" href="css/login.css" />
</head>

<div class="login-page">
    <button class="close-btn" @onclick="ExitApp">✕</button>

    <div class="login-container">

        <div class="logo-section">
            <img src="images/logo_afp.png" class="logo" />
            <h1>DASM-AFP</h1>
        </div>

        <EditForm Model="@loginModel" OnSubmit="HandleLogin">

            <h2 class="login-title">Login</h2>

            <!-- USERNAME -->
            <div class="input-wrapper @(usernameError ? "input-error" : "")">
                <i class="fa-solid fa-user"></i>

                <input @bind="loginModel.Username"
                       class="form-control"
                       placeholder="Admin ID"
                       @oninput="ClearError" />
            </div>

            @if (usernameError)
            {
                <span class="error-text">Username is required</span>
            }

            <!-- PASSWORD -->
            <div class="input-wrapper @(passwordError ? "input-error" : "")">
                <i class="fa-solid fa-lock"></i>

                <input @bind="loginModel.Password"
                       type="@passwordType"
                       class="form-control"
                       placeholder="Password" />

                <i class="fa-solid @(passwordType == "password" ? "fa-eye" : "fa-eye-slash") eye-icon"
                   @onclick="TogglePassword"></i>
            </div>

            @if (passwordError)
            {
                <span class="error-text">Password is required</span>
            }

            <!-- LOCK MESSAGE -->
            @if (isLocked)
            {
                <div class="lock-box">
                    🚫 Account locked due to failed attempts
                    <br />
                    Try again in: <b>@remainingMinutes minutes</b>
                </div>
            }

            <!-- LOGIN BUTTON -->
            <button type="submit" class="login-btn">
                @if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Logging in...</span>
                }
                else
                {
                    <span>Log In</span>
                }
            </button>

        </EditForm>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <p class="error-text">@errorMessage</p>
        }

    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;

    private bool isLoading = false;
    private bool usernameError;
    private bool passwordError;

    private string passwordType = "password";

    private int failedAttempts = 0;
    private bool isLocked = false;
    private DateTime lockUntil;

    private int remainingMinutes =>
        isLocked ? (int)Math.Ceiling((lockUntil - DateTime.Now).TotalMinutes) : 0;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            WindowService?.SetLoginMode();
        }
    }

    private void ExitApp()
    {
        WindowService?.ExitApp();
    }

    private async Task HandleLogin()
    {
        ValidateInputs();

        if (isLocked)
        {
            errorMessage = $"Account locked. Try again in {remainingMinutes} minutes.";
            return;
        }

        if (string.IsNullOrWhiteSpace(loginModel.Username) ||
            string.IsNullOrWhiteSpace(loginModel.Password))
        {
            return;
        }

        isLoading = true;
        errorMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/login", loginModel);

            if (!response.IsSuccessStatusCode)
            {
                failedAttempts++;
                errorMessage = "Invalid username or password.";

                if (failedAttempts >= 3)
                {
                    LockAccount();
                    errorMessage = "Too many failed attempts. Account locked for 20 minutes.";
                }

                return;
            }

            failedAttempts = 0;
            isLocked = false;

            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

            if (result == null)
            {
                errorMessage = "Invalid server response.";
                return;
            }

            // ================= ROLE CHECK (ADMIN ONLY APP) =================
            if (result.Role != "Admin")
            {
                errorMessage = "Access denied. This application is for Admin users only.";
                return;
            }

            // ================= STORE SESSION =================
            await SecureStorage.SetAsync("jwt_token", result.Token);
            await SecureStorage.SetAsync("username", result.Username);
            await SecureStorage.SetAsync("role", result.Role);

            WindowService.Attach(App.Current.Windows[0]);
            WindowService.SetMainAppMode();

            await Task.Delay(150);

            Nav.NavigateTo("/dashboard", false);
        }
        catch (Exception ex)
        {
            errorMessage = "Server error: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void LockAccount()
    {
        isLocked = true;
        lockUntil = DateTime.Now.AddMinutes(20);

        _ = Task.Run(async () =>
        {
            while (DateTime.Now < lockUntil)
            {
                await Task.Delay(1000);
                await InvokeAsync(StateHasChanged);
            }

            isLocked = false;
            failedAttempts = 0;
            errorMessage = "";
            await InvokeAsync(StateHasChanged);
        });
    }

    private void ValidateInputs()
    {
        usernameError = string.IsNullOrWhiteSpace(loginModel.Username);
        passwordError = string.IsNullOrWhiteSpace(loginModel.Password);
    }

    private void ClearError(ChangeEventArgs e)
    {
        usernameError = false;
        errorMessage = "";
    }

    private void TogglePassword()
    {
        passwordType = passwordType == "password" ? "text" : "password";
    }
}