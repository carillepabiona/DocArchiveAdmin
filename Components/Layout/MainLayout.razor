@inherits LayoutComponentBase
@inject NavigationManager Nav
@using Microsoft.Maui.Storage
@using DocArchiveAdmin.Services
@inject WindowService WindowService
@implements IDisposable

<div class="app-shell">

    <!-- HEADER (FIXED) -->
    <div class="header">
        <div class="header-left">
            <div class="logo"></div>

            <div class="header-title">
                <h1>DASM-AFP</h1>
                <p>ARMED FORCES OF THE PHILIPPINES</p>
            </div>
        </div>

        <div class="header-right">
            <div class="notification-icon" @onclick="OpenNotifications">
                🔔
                <span class="notification-badge">@notificationCount</span>
            </div>

            <div class="user-menu-wrapper">
                <div class="user-info" @onclick="ToggleUserMenu">
                    <div class="user-details">
                        <div class="user-name">@fullName</div>
                        <div class="user-role">@role</div>
                    </div>
                    <div class="user-avatar">@initials</div>
                </div>

                @if (showUserMenu)
                {
                    <div class="user-menu-dropdown">
                        <button class="user-menu-item" @onclick="GoProfile">
                            👤 Profile
                        </button>

                        <div class="menu-divider"></div>

                        <button class="user-menu-item sign-out" @onclick="HandleSignOut">
                            🚪 Sign Out
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main-container">

        <!-- SIDEBAR (FIXED) -->
        <div class="sidebar">
            <button class="nav-button @(currentPage == "dashboard" ? "active" : "")" @onclick="GoDashboard">📊 Dashboard</button>
            <button class="nav-button @(currentPage == "user-management" ? "active" : "")" @onclick="GoUserManagement">👥 Users</button>
            <button class="nav-button @(currentPage == "documents" ? "active" : "")" @onclick="GoDocuments">📁 Documents</button>
            <button class="nav-button @(currentPage == "create-user" ? "active" : "")" @onclick="GoCreateUser">👤 Create User</button>
            <button class="nav-button @(currentPage == "settings" ? "active" : "")" @onclick="GoSettings">⚙️ Settings</button>
        </div>

        <!-- CONTENT (ONLY SCROLLABLE) -->
        <div class="content">
            @Body
        </div>

    </div>

    <!-- NOTIFICATIONS -->
    @if (showNotificationsPanel)
    {
        <div class="notifications-panel">
            <div class="notifications-header">
                <h3>Notifications</h3>
                <button @onclick="CloseNotifications">✕</button>
            </div>

            <div class="notifications-list">
                @foreach (var n in notifications)
                {
                    <div class="notification-item">
                        <div class="notification-content">
                            <p>@n.Title</p>
                            <small>@n.Time</small>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</div>

@code {

    private string? fullName;
    private string? role;
    private string? initials;

    private string currentPage = "dashboard";

    private bool showNotificationsPanel = false;
    private bool showUserMenu = false;
    private int notificationCount = 1;

    private List<Notification> notifications = new()
    {
        new Notification { Id = 1, Title = "Your document has been reviewed", Time = "2 hours ago" },
        new Notification { Id = 2, Title = "New security alert", Time = "5 hours ago" },
        new Notification { Id = 3, Title = "System maintenance scheduled", Time = "1 day ago" }
    };

    // ✅ INIT
    protected override async Task OnInitializedAsync()
    {
        fullName = await SecureStorage.GetAsync("username") ?? "User";
        role = await SecureStorage.GetAsync("role") ?? "Officer";

        if (!string.IsNullOrEmpty(fullName))
        {
            var parts = fullName.Split(' ');
            initials = string.Join("", parts.Select(p => p[0])).ToUpper();
        }
        else
        {
            initials = "U";
        }

        UpdateCurrentPage();

        // ✅ subscribe to route changes
        Nav.LocationChanged += OnLocationChanged;
    }

    // ✅ route change handler
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateCurrentPage();
        showUserMenu = false;
        showNotificationsPanel = false;
        StateHasChanged();
    }

    // ✅ detect current page
    private void UpdateCurrentPage()
    {
        var uri = Nav.Uri.ToLower();

        if (uri.Contains("/dashboard"))
            currentPage = "dashboard";
        else if (uri.Contains("/documents"))
            currentPage = "documents";
        else if (uri.Contains("/user-management"))
            currentPage = "user-management";
        else if (uri.Contains("/create-user"))
            currentPage = "create-user";
        else if (uri.Contains("/settings"))
            currentPage = "settings";
        else if (uri.Contains("/profile-user"))
            currentPage = "profile-user";
        else
            currentPage = "dashboard";
    }

    // ✅ NAVIGATION METHODS
    private void GoDashboard()
    {
        showUserMenu = false;
        Nav.NavigateTo("/dashboard");
    }

    private void GoDocuments()
    {
        showUserMenu = false;
        Nav.NavigateTo("/documents");
    }

    private void GoUserManagement()
    {
        showUserMenu = false;
        Nav.NavigateTo("/user-management");
    }

    private void GoCreateUser()
    {
        showUserMenu = false;
        Nav.NavigateTo("/create-user");
    }

    private void GoSettings()
    {
        showUserMenu = false;
        Nav.NavigateTo("/settings");
    }

    private void GoProfile()
    {
        showUserMenu = false;
        Nav.NavigateTo("/profile-user");
    }

    // ✅ USER MENU
    private void ToggleUserMenu()
    {
        showUserMenu = !showUserMenu;
        showNotificationsPanel = false;
    }

    // ✅ SIGN OUT
    private async Task HandleSignOut()
    {
        showUserMenu = false;

        // Clear secure storage
        SecureStorage.Remove("jwt_token");
        SecureStorage.Remove("username");
        SecureStorage.Remove("role");

        // Navigate to login
        Nav.NavigateTo("/", true);
    }

    // ✅ NOTIFICATIONS
    private void OpenNotifications()
    {
        showNotificationsPanel = !showNotificationsPanel;
        showUserMenu = false;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            WindowService.Attach(App.Current.Windows[0]);
        }
    }

    private void CloseNotifications()
    {
        showNotificationsPanel = false;
    }

    // ✅ CLEAN DISPOSE
    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    // ✅ MODEL
    public class Notification
    {
        public int Id { get; set; }
        public string Title { get; set; }
        public string Time { get; set; }
    }
}
